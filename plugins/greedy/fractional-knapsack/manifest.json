    "time_worst": "O(n log n)",
    "space": "O(1)"
  },
  "parameters": {
    "array_size": {
      "type": "integer",
      "label": "Number of items",
      "min": 4,
      "max": 10,
      "default": 6
    }
  },
  "tags": ["greedy", "fractional-knapsack", "optimization", "ratio"],
  "references": [
    {
