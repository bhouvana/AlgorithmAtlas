  "complexity": {
    "time_best": "O(E log E)",
    "time_average": "O(E log E)",
    "time_worst": "O(E log E)",
    "space": "O(V)"
  },
  "parameters": {
    "node_count": {
      "type": "integer",
      "label": "Node count",
      "min": 4,
      "max": 10,
      "default": 7
    }
  },
  "tags": ["graph", "mst", "greedy", "union-find", "spanning-tree", "weighted"],
  "references": [
    {
      "type": "article",
      "title": "Kruskal's algorithm — Wikipedia",
      "url": "https://en.wikipedia.org/wiki/Kruskal%27s_algorithm"
    }
  ]
