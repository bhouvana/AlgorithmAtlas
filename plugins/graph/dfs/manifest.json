{
  "schema_version": "1.0",
  "id": "dfs",
  "name": "Depth-First Search",
  "version": "1.0.0",
  "category": "graph",
  "visualization_type": "GRAPH",
  "execution_target": "server",
  "entry_point": "algorithm.py",
  "description": "Explores a graph by going as deep as possible along each branch before backtracking.",
  "intuition": "Navigate a maze by always taking the first unexplored passage — backtrack only when you hit a dead end.",
  "complexity": {
    "time_best": "O(V + E)",
    "time_average": "O(V + E)",
    "time_worst": "O(V + E)",
    "space": "O(V)"
  },
  "tags": ["graph", "traversal", "stack", "backtracking", "depth"],
  "parameters": {
    "node_count": {
      "type": "integer",
      "min": 3,
      "max": 12,
      "default": 8,
      "label": "Node Count"
    },
    "extra_edges": {
      "type": "integer",
      "min": 0,
      "max": 10,
      "default": 3,
      "label": "Extra Edges"
    },
    "start_node": {
      "type": "choice",
      "choices": ["A", "B", "C", "D", "E", "F", "G", "H"],
      "default": "A",
      "label": "Start Node"
    },
    "seed": {
      "type": "integer",
      "min": 0,
      "max": 9999,
      "default": 42,
      "label": "Random Seed"
    }
  },
  "benchmark_enabled": true
}
