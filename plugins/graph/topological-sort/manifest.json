{
  "schema_version": "1.0",
  "id": "topological-sort",
  "name": "Topological Sort (Kahn's)",
  "version": "1.0.0",
  "category": "graph",
  "visualization_type": "GRAPH",
  "entry_point": "algorithm.py",
  "benchmark_enabled": true,
  "description": "Orders nodes of a DAG such that every directed edge u→v has u before v, using Kahn's BFS algorithm.",
  "intuition": "Repeatedly remove nodes with no incoming edges. Each removed node goes into the result. A node can only be removed when all its prerequisites are done.",
  "complexity": {
    "time_best": "O(V + E)",
    "time_average": "O(V + E)",
    "time_worst": "O(V + E)",
    "space": "O(V)"
  },
  "parameters": {
    "node_count": {
      "type": "integer",
      "label": "Node count",
      "min": 4,
      "max": 10,
      "default": 7
    }
  },
  "tags": ["graph", "dag", "topological-sort", "kahn", "scheduling"],
  "references": [
    {
      "type": "article",
      "title": "Topological sorting — Wikipedia",
      "url": "https://en.wikipedia.org/wiki/Topological_sorting"
    }
  ]
