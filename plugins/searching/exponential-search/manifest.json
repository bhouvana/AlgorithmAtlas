{
  "schema_version": "1.0",
  "id": "exponential-search",
  "name": "Exponential Search",
  "version": "1.0.0",
  "category": "searching",
  "visualization_type": "ARRAY_BARS_SEARCH",
  "execution_target": "server",
  "entry_point": "algorithm.py",
  "description": "Finds the range where the target may exist by doubling the index, then binary searches within that range.",
  "intuition": "Double your search range each time (1, 2, 4, 8, 16…) until you overshoot, then binary search the last range.",
  "complexity": {
    "time_best": "O(1)",
    "time_average": "O(log n)",
    "time_worst": "O(log n)",
    "space": "O(1)"
  },
  "tags": ["searching", "sorted", "exponential", "unbounded"],
  "parameters": {
    "array_size": {
      "type": "integer",
      "min": 4,
      "max": 100,
      "default": 20,
      "label": "Array Size"
    },
    "target_position": {
      "type": "choice",
      "choices": ["first", "middle", "last", "missing"],
      "default": "middle",
      "label": "Target Position"
    },
    "seed": {
      "type": "integer",
      "min": 0,
      "max": 9999,
      "default": 42,
      "label": "Random Seed"
    }
  },
  "benchmark_enabled": true
}
