{
  "schema_version": "1.0",
  "id": "min-path-sum",
  "name": "Minimum Path Sum",
  "version": "1.0.0",
  "category": "dynamic-programming",
  "visualization_type": "MATRIX",
  "entry_point": "algorithm.py",
  "benchmark_enabled": true,
  "description": "Find the path from top-left to bottom-right of a grid with minimum total cost.",
  "intuition": "dp[i][j] = grid[i][j] + min(dp[i-1][j], dp[i][j-1]). Can only move right or down.",
  "complexity": {
    "time_best": "O(m·n)",
    "time_average": "O(m·n)",
    "time_worst": "O(m·n)",
    "space": "O(m·n)"
  },
  "parameters": {
    "array_size": {
      "type": "integer",
      "label": "Grid size (n×n)",
      "min": 3,
      "max": 6,
      "default": 4
    }
  },
  "tags": ["dynamic-programming", "grid", "min-path", "shortest-path"],
  "references": []
}
