  "complexity": {
    "time_best": "O(n³)",
    "time_average": "O(n³)",
    "time_worst": "O(n³)",
    "space": "O(n²)"
  },
  "parameters": {
    "array_size": {
      "type": "integer",
      "label": "Number of matrices",
      "min": 3,
      "max": 6,
      "default": 4
    }
  },
