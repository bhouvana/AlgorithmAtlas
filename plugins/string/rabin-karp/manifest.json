  "complexity": {
    "time_best": "O(n + m)",
    "time_average": "O(n + m)",
    "time_worst": "O(n·m)",
    "space": "O(1)"
  },
  "parameters": {
    "text_length": {
      "type": "integer",
      "label": "Text length",
      "min": 16,
      "max": 32,
      "default": 20
    }
