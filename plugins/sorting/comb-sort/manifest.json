    "time_best": "O(n log n)",
    "time_average": "O(n²/2^p)",
    "time_worst": "O(n²)",
    "space": "O(1)"
  },
  "parameters": {
    "array_size": {
      "type": "integer",
      "label": "Array size",
      "min": 5,
      "max": 20,
      "default": 10
    }
