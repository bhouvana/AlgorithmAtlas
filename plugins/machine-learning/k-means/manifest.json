    "point_count": {
      "type": "integer",
      "label": "Number of points",
      "min": 8,
      "max": 20,
      "default": 12
    },
    "k": {
      "type": "integer",
      "label": "Number of clusters (k)",
      "min": 2,
      "max": 4,
      "default": 3
    }
  },
