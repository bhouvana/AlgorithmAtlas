# Algorithm Atlas — environment variable template
# Copy to .env and fill in values before running

# ── Application ─────────────────────────────────────────────────────────────
APP_NAME="Algorithm Atlas"
DEBUG=true
LOG_LEVEL=DEBUG

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# CORS — restrict in production
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ── Plugin discovery ─────────────────────────────────────────────────────────
# Absolute path to the plugins/ directory
# PLUGIN_ROOT=/path/to/algorithm-atlas/plugins

# ── Database (Phase 1+) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://atlas:atlas@localhost:5432/atlas

# ── Redis (Phase 1+) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Atlas AI ─────────────────────────────────────────────────────────────────
# All keys below are pooled behind a RotatingProvider (see
# apps/backend/algorithm_atlas/ai/provider.py): requests round-robin across
# whichever are configured and fall forward to the next one on a rate limit
# or outage. At least one is required; set as many as you have for resilience
# in production (this is what render.yaml wires up for the deployed backend).
GROQ_API_KEY=gsk_...your_key_here...
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama Cloud (ollama.com) — two separate keys so the pool has two
# independent rate-limit budgets, not just one.
OLLAMA_API_KEY_1=...your_first_ollama_cloud_key_here...
OLLAMA_API_KEY_2=...your_second_ollama_cloud_key_here...
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_BASE_URL=https://ollama.com/v1

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
