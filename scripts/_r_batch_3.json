   "lang": "javascript",
   "file": "scale_greedy_math_cluster.py",
   "code": "function can_complete_circuit(gas, cost) {\n    let total = 0, tank = 0, start = 0;\n    for (let i=0;i<gas.length;i++) {\n        const diff = gas[i]-cost[i]; total += diff; tank += diff;\n        if (tank < 0) { start = i+1; tank = 0; }\n    }\n    return (total >= 0 ? start : -1);\n}\n"
  }
 },
