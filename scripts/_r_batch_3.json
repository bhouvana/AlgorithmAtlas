  "reference": {
   "lang": "javascript",
   "file": "scale_greedy_math_cluster.py",
   "code": "function euler_totient(n) {\n    let result = n; let x = n; let p = 2;\n    while (p*p <= x) {\n        if (x % p === 0) { while (x % p === 0) x = Math.floor(x/p); result -= Math.floor(result/p); }\n        p++;\n    }\n    if (x > 1) result -= Math.floor(result/x);\n    return result;\n}\n"
  }
 },
