   "return_type": {
    "kind": "integer"
   }
  },
  "reference": {
   "lang": "javascript",
   "file": "scale_mega_cluster3.py",
   "code": "function search(nums, target) {\n    let lo=0, hi=nums.length-1;\n    while (lo<=hi) {\n        const mid=(lo+hi)>>1;\n        if (nums[mid]===target) return mid;\n        if (nums[lo]<=nums[mid]) { if (nums[lo]<=target && target<nums[mid]) hi=mid-1; else lo=mid+1; }\n        else { if (nums[mid]<target && target<=nums[hi]) lo=mid+1; else hi=mid-1; }\n    }\n    return -1;\n}\n"
  }
 },
