  "reference": {
   "lang": "javascript",
   "file": "scale_mega_cluster3.py",
   "code": "function num_subarrays_product_less_than_k(nums, k) {\n    if (k<=1) return 0;\n    let prod=1, left=0, count=0;\n    for (let right=0;right<nums.length;right++) {\n        prod*=nums[right];\n        while (prod>=k) { prod/=nums[left]; left++; }\n        count += right-left+1;\n    }\n    return count;\n}\n"
  }
 },
