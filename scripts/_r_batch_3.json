   "file": "scale_mega_cluster6.py",
   "code": "function count_unique_permutations(nums) {\n    function fact(n) { let r=1; for (let i=2;i<=n;i++) r*=i; return r; }\n    const freq={};\n    for (const x of nums) freq[x]=(freq[x]||0)+1;\n    let denom=1; for (const k in freq) denom*=fact(freq[k]);\n    return Math.round(fact(nums.length)/denom);\n}\n"
  }
 },
