 "lucas-theorem": {
  "id": "lucas-theorem",
  "contract": {
   "function_name": "lucas_theorem",
   "parameters": [
    {
     "name": "n",
     "type": {
      "kind": "integer"
     }
    },
    {
     "name": "k",
     "type": {
      "kind": "integer"
     }
    },
    {
     "name": "p",
     "type": {
      "kind": "integer"
     }
    }
   ],
   "return_type": {
    "kind": "integer"
   }
  },
  "reference": {
   "lang": "javascript",
   "file": "scale_mega_cluster4.py",
   "code": "function lucas_theorem(n, k, p) {\n    function smallComb(nn, kk) {\n        if (kk>nn || kk<0) return 0;\n        let num=1, den=1;\n        for (let i=0;i<kk;i++) { num=(num*((nn-i)%p))%p; den=(den*(i+1))%p; }\n        let denInv=1, base=den%p, e=p-2;\n        while (e>0) { if (e&1) denInv=(denInv*base)%p; base=(base*base)%p; e>>=1; }\n        return (num*denInv)%p;\n    }\n    let result=1, nn=n, kk=k;\n    while (nn>0 || kk>0) {\n        const ni=nn%p, ki=kk%p;\n        if (ki>ni) return 0;\n        result=(result*smallComb(ni,ki))%p;\n        nn=Math.floor(nn/p); kk=Math.floor(kk/p);\n    }\n    return result;\n}\n"
  }
 },
